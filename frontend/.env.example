# URL of your deployed backend (Render), no trailing slash.
# For local dev against a local backend, leave this pointing at localhost.
VITE_API_URL=http://localhost:5000

# In Netlify: Site settings > Environment variables > add VITE_API_URL
# with your Render URL, e.g. https://sbt-backend.onrender.com

# Google Maps API key (Maps JavaScript API + Places API + Geocoding API enabled),
# used for the "pick on map" customer location picker. Requires a Google Cloud
# billing account (free $200/month credit covers normal shop usage).
# In Netlify: Site settings > Environment variables > add VITE_GOOGLE_MAPS_API_KEY
VITE_GOOGLE_MAPS_API_KEY=
