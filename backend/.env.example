# Server
PORT=5000
NODE_ENV=production

# MongoDB Atlas connection string (create a free cluster at mongodb.com/cloud/atlas)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/sbt?retryWrites=true&w=majority

# Long random string used to sign JWT tokens — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_string

# Comma-separated list of allowed frontend origins (no trailing slash)
# e.g. https://your-app.netlify.app,http://localhost:5173
CORS_ORIGIN=http://localhost:5173
